# Supabase (server-side only — never expose in client)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Site
NEXT_PUBLIC_SITE_URL=https://nevadarealestatemarket.com

# Sitemap lastmod (set at build time in Vercel: BUILD_DATE_ISO=$(date -u +%Y-%m-%dT%H:%M:%SZ))
BUILD_DATE_ISO=2026-05-12T00:00:00Z

# GBP Aggregate Rating (add once you hit 5+ reviews)
# NEXT_PUBLIC_GBP_AGGREGATE_RATING_VALUE=5.0
# NEXT_PUBLIC_GBP_AGGREGATE_RATING_COUNT=12
